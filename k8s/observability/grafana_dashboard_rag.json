{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "title": "Backend RPS (rag-backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"rag-thesis\", pod=~\"rag-backend-.*\"}[1m]))",
          "legendFormat": "backend CPU cores",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Ollama GPU utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "avg by(Hostname)(DCGM_FI_DEV_GPU_UTIL)",
          "legendFormat": "{{Hostname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "title": "Ollama VRAM used (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "avg by(Hostname)(DCGM_FI_DEV_FB_USED)",
          "legendFormat": "{{Hostname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] }
    },
    {
      "title": "Qdrant RSS (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"rag-thesis\", pod=~\"qdrant-.*\"}) / 1024 / 1024",
          "legendFormat": "qdrant working set MiB",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] }
    },
    {
      "title": "HPA current replicas (backend + ollama)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"rag-thesis\"}",
          "legendFormat": "{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "Pod memory working set (rag-thesis)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by(pod)(container_memory_working_set_bytes{namespace=\"rag-thesis\"}) / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
